# Configuración del Servidor
PORT=3001
NODE_ENV=development

# Base de Datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password
DB_NAME=gestor_vacaciones

# JWT
JWT_SECRET=tu_clave_secreta_muy_segura_cambiar_en_produccion
JWT_EXPIRES_IN=24h

# Email (para notificaciones con Outlook/Office 365)
# Para Office 365, necesitas habilitar "SMTP autenticado" en admin.microsoft.com
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your-email-here
SMTP_PASS=your-password-here
EMAIL_FROM=your-email-here

# Frontend URL (origen del SPA; el portal se sirve en la raíz, sin prefijo).
FRONTEND_URL=http://localhost:3000

# URL pública completa del SPA (enlaces en correos). Si se omite se usa FRONTEND_URL.
# FRONTEND_APP_URL=http://96.126.124.60

# API URL (para enlaces en emails de aprobación)
API_URL=http://localhost:3001/api

# Bolsa de horas / proyectos globales (además de rol admin quién puede CRUD proyecto y cargar lista total):
# Lista separada por comas si hay varios. Si se omite, se usa CONTROL_PROYECTOS_VERONICA_EMAIL o por defecto asistente@prayaga.biz.
# CONTROL_PROYECTOS_GESTORES_EMAIL=asistente@prayaga.biz
# Una sola cuenta (retrocompat): por defecto asistente@prayaga.biz si no existe GESTORES.
# CONTROL_PROYECTOS_VERONICA_EMAIL=asistente@prayaga.biz

# Reembolsos (opcional): forzar qué fila de empleados es el aprobador. Si se omite, se detecta Enrique Agapito en BD.
# REEMBOLSOS_APROBADOR_EMPLEADO_ID=3

# Tamaño máximo del comprobante adjunto en reintegros (MB). Por defecto 10. nginx suele tener client_max_body_size aparte.
# REEMBOLSOS_MAX_UPLOAD_MB=25

# Caja chica: correo del resumen mensual (por defecto Rocío Picón)
# CAJA_CHICA_EMAIL_ROCIO=rocio.picon@prayaga.biz
# Segundo destinatario del mismo correo (mismo PDF). Por defecto Enrique Agapito. Vacío = solo Rocío.
# CAJA_CHICA_EMAIL_COPIA=enrique.agapito@prayaga.biz

# ============================================================
# Asistente IA (Gemini) — solo para rol admin, nivel 1 (lectura)
# ============================================================
# API key gratuita de Google AI Studio: https://aistudio.google.com/apikey
# Tier gratuito Gemini Flash: 1.500 requests/día sin tarjeta.
GEMINI_API_KEY=
# Modelo a usar (opcional). Por defecto gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash


